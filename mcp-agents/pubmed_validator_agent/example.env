# NCBI API key — optional but raises rate limit from 3 to 10 req/s
# Register at: https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=

# Max PubMed results fetched per keyword search query
PUBMED_MAX_RESULTS=5

# How long (seconds) to cache PubMed results for identical queries
CACHE_TTL_SECONDS=3600

# MCP server binding
MCP_HOST=0.0.0.0
MCP_PORT=6351
